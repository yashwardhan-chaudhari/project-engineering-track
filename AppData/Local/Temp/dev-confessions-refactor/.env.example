# Environment Variables - Dev Confessions API
# Copy this file to .env and fill in actual values
# Never commit .env to git - it contains secrets

# Server Configuration
PORT=3000

# Database Configuration  
DB_URL=mongodb://localhost:27017
DB_NAME=confessions

# External API Configuration
API_BASE_URL=https://api.example.com/v1

# API Endpoints (used by external integrations)
API_CONFESSIONS_ENDPOINT=https://api.example.com/v1/confessions
API_TRENDING_ENDPOINT=https://api.example.com/v1/trending
API_STATS_ENDPOINT=https://api.example.com/v1/users
API_AUTH_ENDPOINT=https://api.example.com/v1/auth/validate
API_RECOMMENDATIONS_ENDPOINT=https://api.example.com/v1/recommendations
API_ANALYTICS_ENDPOINT=https://api.example.com/v1/analytics/log
API_WEBHOOK_ENDPOINT=https://api.example.com/v1/webhooks/process

# Environment
NODE_ENV=development
